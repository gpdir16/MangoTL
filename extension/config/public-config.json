{
    "defaults": {
        "sourceLanguage": "ja",
        "targetLanguage": "ko"
    },
    "languages": {
        "sources": [
            {
                "code": "ja",
                "label": "Japanese"
            },
            {
                "code": "ko",
                "label": "Korean"
            },
            {
                "code": "en",
                "label": "English"
            },
            {
                "code": "latin",
                "label": "Latin Script"
            }
        ],
        "targets": [
            {
                "code": "ko",
                "label": "Korean"
            },
            {
                "code": "ja",
                "label": "Japanese"
            },
            {
                "code": "en",
                "label": "English"
            },
            {
                "code": "zh",
                "label": "Chinese"
            }
        ]
    },
    "websites": [
        {
            "id": "pixiv",
            "name": "Pixiv",
            "sourceLanguage": "ja",
            "hostPatterns": ["pixiv.net", "*.pixiv.net"],
            "imageSelectors": ["main img[src*='pximg.net']", "article img[src*='pximg.net']", "img[src*='i.pximg.net']"],
            "includeUrlPatterns": ["/img-original/", "/img-master/"],
            "excludeUrlPatterns": ["/custom-thumb/", "/c/", "/soy/", "/common/", "/static/"],
            "minImageWidth": 300,
            "minImageHeight": 300,
            "urlNormalizer": {
                "stripHash": true,
                "stripQuery": true
            },
            "imageKeyPattern": {
                "match": "/img-[^/]+/img/(.+?)(?:_master1200|_square1200|_custom1200)?\\.(?:jpg|jpeg|png|webp)$",
                "group": 1,
                "flags": "i"
            }
        }
    ]
}
